{
  "name": "aston-bufet-worker",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute aston-bufet-db --local --file=db/migrations/001_schema.sql",
    "db:migrate:remote": "wrangler d1 execute aston-bufet-db --remote --file=db/migrations/001_schema.sql",
    "db:seed:local": "wrangler d1 execute aston-bufet-db --local --file=db/migrations/002_seed.sql",
    "db:seed:remote": "wrangler d1 execute aston-bufet-db --remote --file=db/migrations/002_seed.sql"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "wrangler": "^3.99.0",
    "typescript": "^5.7.0"
  }
}
